{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "web": {
      "root": ".",
      "framework": "nextjs"
    },
    "eve": {
      "root": ".",
      "framework": "eve",
      "buildCommand": "node ./node_modules/eve/bin/eve.js build"
    }
  },
  "rewrites": [
    {
      "source": "/eve/v1/(.*)",
      "destination": {
        "service": "eve"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "web"
      }
    }
  ]
}
